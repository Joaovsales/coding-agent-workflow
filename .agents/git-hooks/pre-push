#!/usr/bin/env bash
# pre-push — runs typecheck + lint before every git push.
# Installed by coding-agent-workflow/install.sh into .git/hooks/pre-push.
# Harness-agnostic: works for manual pushes, Claude Code, Pi, and CI.
#
# Kill switch: SKIP_PREPUSH=1 git push

set -uo pipefail

[ "${SKIP_PREPUSH:-0}" = "1" ] && exit 0

# Block force pushes unless explicitly allowed.
for arg in "$@"; do
  if [[ "$arg" == "--force" || "$arg" == "-f" ]]; then
    if [ "${ALLOW_FORCE_PUSH:-0}" != "1" ]; then
      echo "BLOCKED: force push. Set ALLOW_FORCE_PUSH=1 to override." >&2
      exit 1
    fi
  fi
done

# Run typecheck + lint if package.json declares them.
if [ -f package.json ] && command -v jq >/dev/null 2>&1; then
  SCRIPTS=$(jq -r '.scripts // {} | keys[]' package.json 2>/dev/null || true)
  for script in typecheck lint; do
    if printf '%s\n' "$SCRIPTS" | grep -qx "$script"; then
      echo "[pre-push] running: npm run $script"
      if ! npm run --silent "$script" >/tmp/prepush-"$script".log 2>&1; then
        echo "BLOCKED: npm run $script failed. See /tmp/prepush-${script}.log" >&2
        tail -30 /tmp/prepush-"$script".log >&2
        exit 1
      fi
    fi
  done
fi

exit 0
